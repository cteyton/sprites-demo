# Copy to .env.michel (gitignored) and fill in real values.
# WEBHOOK_SECRET: shared secret with the GitHub webhook config. Generate with:
#   openssl rand -hex 32
WEBHOOK_SECRET=replace-with-openssl-rand-hex-32

# CSV of owner/repo allowed to trigger michel.
ALLOWED_REPOS=cteyton/sprites-demo

# CSV of comment.author_association values allowed to trigger michel.
# Defaults to OWNER,MEMBER,COLLABORATOR if unset.
ALLOWED_ASSOCIATIONS=OWNER,MEMBER,COLLABORATOR

# Absolute paths inside the sprite.
MICHEL_SCRIPT=/home/sprite/workspace/scripts/run-michel.sh
DISPATCH_SCRIPT=/home/sprite/workspace/scripts/dispatch-michel.sh
WORKDIR=/home/sprite/workspace

# --- Worker pool (Option B2) ---
# The controller dispatches each @michel run to a worker sprite. Real
# parallelism = number of workers. Provision each with:
#   bash scripts/provision-worker.sh <worker-name>
# CSV of worker sprite names:
WORKER_SPRITES=michel-worker-1
# Per-worker clean-checkpoint id (provision-worker.sh fills these in; '-'→'_'):
WORKER_CLEAN_CKPT_michel_worker_1=

# Org the worker/controller sprites live in (passed as -o to sprite calls).
CONTROLLER_ORG=cedric-teyton

# Sprite API token so the CONTROLLER can drive worker sprites headlessly.
# Get it from `sprite org list` / your Sprites dashboard. Format:
#   <org>/<token-id>/<name>/<value>
SPRITE_TOKEN=replace-with-sprite-api-token
